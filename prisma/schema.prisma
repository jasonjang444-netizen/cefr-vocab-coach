generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  username      String?
  passwordHash  String?
  loginProvider String    @default("email")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userLevel       UserLevel?
  vocabProgress   UserVocabProgress[]
  studySessions   StudySession[]
  quizResults     QuizResult[]
  placementResult PlacementTestResult?
  studyPlan       StudyPlan?
}

model UserLevel {
  id             String   @id @default(cuid())
  userId         String   @unique
  currentCefr    String   @default("A1")
  targetCefr     String   @default("B1")
  studyMinutes   Int      @default(20)
  onboardingDone Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PlacementTestResult {
  id         String   @id @default(cuid())
  userId     String   @unique
  level      String
  score      Int
  confidence String
  strengths  String
  weaknesses String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Vocabulary {
  id             String   @id @default(cuid())
  word           String
  partOfSpeech   String
  meaning        String
  meaningKo      String?
  example        String
  exampleKo      String?
  collocations   String
  collocationsKo String?
  cefrLevel      String
  createdAt      DateTime @default(now())

  userProgress UserVocabProgress[]
}

model UserVocabProgress {
  id           String   @id @default(cuid())
  userId       String
  vocabId      String
  status       String   @default("new")
  lastReviewed DateTime?
  timesCorrect Int      @default(0)
  timesWrong   Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocab Vocabulary @relation(fields: [vocabId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabId])
}

model StudySession {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime @default(now())
  wordsStudied  Int      @default(0)
  wordsReviewed Int      @default(0)
  minutesSpent  Int      @default(0)
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QuizResult {
  id        String   @id @default(cuid())
  userId    String
  score     Int
  total     Int
  quizType  String   @default("daily")
  answers   String   @default("[]")
  date      DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudyPlan {
  id            String   @id @default(cuid())
  userId        String   @unique
  dailyNewWords Int      @default(10)
  dailyReview   Int      @default(5)
  collocations  Int      @default(3)
  examples      Int      @default(3)
  miniQuiz      Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
